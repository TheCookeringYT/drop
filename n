<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Eaglercraft Launcher</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;900&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
 
  :root {
    --red: #ff0000;
    --red-dark: #ff0000;
    --bg: #000;
    --font: 'Nunito', sans-serif;
  }
 
  html, body {
    height: 100%; width: 100%;
    background: var(--bg);
    font-family: var(--font);
    color: #ff000;
    overflow: hidden;
  }
 
  #screen-select {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 28px;
    padding: 32px 24px;
    animation: fadeIn 0.4s ease;
  }
 
  #screen-select.exit {
    animation: exitUp 0.3s ease forwards;
  }
 
  .select-heading { text-align: center; }
  .select-heading h1 { font-size: 20px; font-weight: 900; letter-spacing: 0.04em; color: #fff; margin-bottom: 6px; }
  .select-heading p  { font-size: 11px; font-weight: 600; letter-spacing: 0.16em; text-transform: uppercase; color: #2a2a2a; }
 
  .select-row {
    display: flex;
    align-items: center;
    gap: 12px;
    width: 100%;
    max-width: 680px;
  }
 
  .pill-wrap { flex: 1; position: relative; }
 
  .pill-trigger {
    width: 100%;
    background: var(--red);
    border: none;
    border-radius: 999px;
    padding: 16px 22px;
    font-family: var(--font);
    font-size: 16px; font-weight: 700; color: #fff;
    cursor: pointer;
    display: flex; align-items: center; justify-content: space-between; gap: 12px;
    transition: background 0.13s, border-radius 0.15s, transform 0.12s;
    outline: none;
  }
 
  .pill-trigger:hover { background: #e50000; transform: translateY(-1px); }
  .pill-trigger.open  { border-radius: 22px 22px 0 0; background: var(--red-dark); transform: none; }
 
  .pill-label { flex: 1; text-align: left; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; opacity: 0.8; }
  .pill-label.chosen { opacity: 1; }
 
  .pill-chevron { width: 20px; height: 20px; flex-shrink: 0; transition: transform 0.2s; }
  .pill-trigger.open .pill-chevron { transform: rotate(180deg); }
 
  .drop-menu {
    display: none;
    position: absolute;
    top: 100%; left: 0; right: 0;
    background: #130000;
    border: 1px solid #3a0000;
    border-top: none;
    border-radius: 0 0 22px 22px;
    max-height: 300px;
    overflow-y: auto;
    z-index: 200;
  }
 
  .drop-menu.open { display: block; animation: menuSlide 0.16s ease; }
  .drop-menu::-webkit-scrollbar { width: 4px; }
  .drop-menu::-webkit-scrollbar-thumb { background: #3a0000; border-radius: 2px; }
 
  .group-hdr {
    padding: 10px 20px 3px;
    font-size: 8.5px; font-weight: 800; letter-spacing: 0.22em; text-transform: uppercase;
    color: #3a0000; border-top: 1px solid #1e0000;
  }
  .group-hdr:first-child { border-top: none; }
 
  .drop-item {
    padding: 11px 20px;
    font-size: 14px; font-weight: 700; color: #bbb;
    cursor: pointer; display: flex; align-items: center; gap: 10px;
    transition: background 0.1s, color 0.1s;
  }
  .drop-item:hover { background: rgba(255,0,0,0.13); color: #fff; }
  .drop-item:last-child { border-radius: 0 0 22px 22px; }
 
  .item-sz { margin-left: auto; font-size: 9.5px; font-weight: 600; color: #2e0000; flex-shrink: 0; }
 
  .badge { font-size: 8px; font-weight: 800; letter-spacing: 0.06em; text-transform: uppercase; border-radius: 3px; padding: 2px 5px; flex-shrink: 0; }
  .badge-wisp { background: #4a0aff; color: #fff; }
  .badge-wasm { background: #883300; color: #fff; }
 
  /* Action buttons — shown after selection, same row */
  .action-btns {
    display: flex;
    gap: 10px;
    flex-shrink: 0;
  }
 
  .launch-pill {
    background: #0d0000;
    border: 2px solid #330000;
    border-radius: 999px;
    padding: 14px 32px;
    font-family: var(--font);
    font-size: 16px; font-weight: 900; color: #bd0f0f;
    cursor: pointer; white-space: nowrap;
    transition: background 0.15s, border-color 0.15s, color 0.15s, transform 0.12s;
    letter-spacing: 0.04em;
  }
  .launch-pill:not(:disabled):hover { background: var(--red); border-color: var(--red); color: #fff; transform: translateY(-1px); }
  .launch-pill:disabled { opacity: 0.3; cursor: default; }
 
  .dl-pill {
    background: #0d0000;
    border: 2px solid #330000;
    border-radius: 999px;
    padding: 14px 28px;
    font-family: var(--font);
    font-size: 16px; font-weight: 900; color: #550000;
    cursor: pointer; white-space: nowrap;
    transition: background 0.15s, border-color 0.15s, color 0.15s, transform 0.12s;
    letter-spacing: 0.04em;
    display: none;
  }
  .dl-pill.visible { display: block; }
  .dl-pill:hover { background: #111; border-color: #555; color: #555; transform: translateY(-1px); }
 
  @keyframes fadeIn    { from { opacity: 0; } to { opacity: 1; } }
  @keyframes exitUp    { from { opacity: 1; transform: translateY(0); } to { opacity: 0; transform: translateY(-16px); } }
  @keyframes menuSlide { from { opacity: 0; transform: translateY(-4px); } to { opacity: 1; transform: translateY(0); } }
 
  @media (max-width: 520px) {
    .select-row { flex-direction: column; }
    .action-btns { width: 100%; }
    .launch-pill, .dl-pill { flex: 1; text-align: center; }
  }
</style>
</head>
<body>
 
<div id="screen-select">
  <div class="select-heading">
    <h1>Select a version and click Launch</h1>
    <p>EaglercraftNOA · Eaglercraft Launcher</p>
  </div>
  <div class="select-row">
    <div class="pill-wrap">
      <button class="pill-trigger" id="pillTrigger">
        <span class="pill-label" id="pillLabel">Choose a client…</span>
        <svg class="pill-chevron" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="5 8 10 13 15 8"/>
        </svg>
      </button>
      <div class="drop-menu" id="dropMenu"></div>
    </div>
    <div class="action-btns">
      <button class="dl-pill" id="dlBtn">Download</button>
      <button class="launch-pill" id="launchBtn" disabled>Launch</button>
    </div>
  </div>
</div>
 
<script>
const BASE = "https://eaglercraftnoa.github.io/play/";
const RAW  = "https://raw.githubusercontent.com/EaglercraftNOA/play/main/";
 
const CATALOG = [
  { g:"Modern",  name:"26.1.2 (WASM)",          file:"eaglercraft-26.1.2-WASM_Novix.html",  b:["wasm"],        sz:"63 MB" },
  { g:"Modern",  name:"1.21.11 (WASM)",        file:"Eaglercraft-1-21-11_wasm.html",       b:["wasm"],        sz:"46 MB" },
  { g:"Modern",  name:"1.17 (WASM-GC)",        file:"eaglercraft-1.17-wasm_gc.html",       b:["wasm"],        sz:"48 MB" },
  { g:"Modern",  name:"1.12.2 (WASM-GC)",      file:"Eaglercraft_1.12.2-WASM-GC.html",     b:["wasm"],        sz:"24 MB" },
  { g:"Modern",  name:"1.12.2",                file:"Eaglercraft-1.12.html",               b:[],              sz:"24 MB" },
  { g:"Modern",  name:"1.12 + Wispcraft",      file:"wispcraft-Eaglercraft-1.12.html",     b:["wisp"],        sz:"26 MB" },
  { g:"Modern",  name:"1.11.2",                file:"Eaglercraft-1.11.2.html",             b:[],              sz:"27 MB" },
  { g:"Modern",  name:"1.8.8",                 file:"Eaglercraft-1.8.8.html",              b:[],              sz:"17 MB" },
  { g:"Modern",  name:"1.8 WASM + Wispcraft",  file:"Eaglercraft-1.8_wasm-wispcraft.html", b:["wasm","wisp"], sz:"16 MB" },
  { g:"Modern",  name:"1.7 (WASM)",            file:"Eaglercraft-1.7-wasm.html",           b:["wasm"],        sz:"12 MB" },
  { g:"Modern",  name:"1.6.4",                 file:"Eaglercraft 1.6.4.html",              b:[],              sz:"26 MB" },
  { g:"Modern",  name:"1.5.2",                 file:"1.5.2.html",                          b:[],              sz:"22 MB" },
  { g:"Modern",  name:"1.5 + Wispcraft",       file:"Eaglercraft-1.5-wispcraft.html",      b:["wisp"],        sz:"24 MB" },
  { g:"Modern",  name:"1.4.7 (WASM)",          file:"Eaglercraft_1.4.7-WASM.html",         b:["wasm"],        sz:"38 MB" },
  { g:"Modern",  name:"1.2.5 (WASM)",          file:"Eaglercraft_1.2.5_wasm.html",         b:["wasm"],        sz:"23 MB" },
  { g:"Modern",  name:"1.1",                   file:"Eaglercraft_1.1.html",                b:[],              sz:"8 MB"  },
  { g:"Modern",  name:"1.0.0",                 file:"Eaglercraft_1_0_0.html",              b:[],              sz:"24 MB" },
  { g:"Modern",  name:"Mobile Edition",         file:"Eaglercraft Mobile.html",             b:[],              sz:"15 MB" },
  { g:"Modern",    name:"Beta 1.8.1 (WASM)",     file:"Eaglercraft_beta 1.8.1_WASM.html",    b:["wasm"],        sz:"21 MB" },
  { g:"Modern",    name:"Beta 1.7.3",             file:"Beta_1.7.3.html",                     b:[],              sz:"16 MB" },
  { g:"Modern",    name:"Beta 1.6.4",             file:"Eaglercraft_b-1_6_4.html",            b:[],              sz:"23 MB" },
  { g:"Modern",    name:"Beta b1.1",              file:"Eaglercraft_b1.1.html",               b:[],              sz:"23 MB" },
  { g:"Modern",    name:"Beta 1.3",               file:"eaglercraft-beta-1.3.html",           b:[],              sz:"4 MB"  },
  { g:"Modern",   name:"Alpha 1.3.2",            file:"Eaglercraft_1_3_2.html",              b:[],              sz:"28 MB" },
  { g:"Modern",   name:"Alpha 1.2.6",            file:"eaglercraft-alpha-1.2.6.html",        b:[],              sz:"8 MB"  },
  { g:"Modern",   name:"Infdev (WASM-GC)",       file:"infdev-wasm-gc.html",                 b:[],              sz:"1.4 MB"},
  { g:"Modern",   name:"Indev 20100233",         file:"Eaglercraft_indev_20100233.html",      b:[],              sz:"21 MB" },
  { g:"Modern",   name:"Indev",         file:"eagler-indev.html",                   b:[],              sz:"1.1 MB"},
  { g:"Modern",   name:"Pre-Release 160052",     file:"pre-release-160052.html",             b:[],              sz:"0.9 MB"},
  { g:"Modern",   name:"rd-132328 (WASM)",       file:"rd-132328-WASM.html",                 b:[],              sz:"0.9 MB"},
  { g:"Modern", name:"Classic 0.30 (WASM)",    file:"eaglercraft-classic-0.30-WASM.html",  b:[],              sz:"3.6 MB"},
];
 
const BADGE_CFG = {
  wisp: { cls:"badge-wisp", label:"Wisp" },
  wasm: { cls:"badge-wasm", label:"WASM" },
};
const ORDER = ["Modern",];
 
const pillTrigger = document.getElementById("pillTrigger");
const pillLabel   = document.getElementById("pillLabel");
const dropMenu    = document.getElementById("dropMenu");
const launchBtn   = document.getElementById("launchBtn");
const dlBtn       = document.getElementById("dlBtn");
 
let menuOpen = false;
let selected = null;
 
// Build dropdown
const groups = {};
CATALOG.forEach(e => { if (!groups[e.g]) groups[e.g]=[]; groups[e.g].push(e); });
ORDER.forEach(g => {
  if (!groups[g]) return;
  const hdr = document.createElement("div");
  hdr.className = "group-hdr"; hdr.textContent = g;
  dropMenu.appendChild(hdr);
  groups[g].forEach(entry => {
    const el = document.createElement("div");
    el.className = "drop-item";
    const badges = entry.b.filter(b => BADGE_CFG[b])
      .map(b => `<span class="badge ${BADGE_CFG[b].cls}">${BADGE_CFG[b].label}</span>`).join("");
    el.innerHTML = `${badges}<span>${entry.name}</span><span class="item-sz">${entry.sz}</span>`;
    el.addEventListener("click", () => {
      selected = entry;
      pillLabel.textContent = entry.name;
      pillLabel.classList.add("chosen");
      launchBtn.disabled = false;
      dlBtn.classList.add("visible");
      closeMenu();
    });
    dropMenu.appendChild(el);
  });
});
 
function openMenu()  { menuOpen = true;  dropMenu.classList.add("open");  pillTrigger.classList.add("open"); }
function closeMenu() { menuOpen = false; dropMenu.classList.remove("open"); pillTrigger.classList.remove("open"); }
pillTrigger.addEventListener("click", () => menuOpen ? closeMenu() : openMenu());
document.addEventListener("click", e => {
  if (!pillTrigger.contains(e.target) && !dropMenu.contains(e.target)) closeMenu();
});
 
launchBtn.addEventListener("click", () => {
  if (!selected) return;
  window.open(BASE + encodeURIComponent(selected.file), "_blank");
});
 
dlBtn.addEventListener("click", async () => {
  if (!selected) return;
  const rawUrl = RAW + encodeURIComponent(selected.file);
  dlBtn.textContent = "Downloading…";
  try {
    const res = await fetch(rawUrl);
    const blob = await res.blob();
    const a = document.createElement("a");
    a.href = URL.createObjectURL(blob);
    a.download = selected.file;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(a.href);
  } catch(e) {
    alert("Download failed.");
  }
  dlBtn.textContent = "Download";
});
</script>
</body>
</html>
